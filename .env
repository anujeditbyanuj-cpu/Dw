# ─────────────────────────────────────────
# DiskWala Bot — Environment Variables
# Developer: @anujedits76
# ─────────────────────────────────────────

# ── Telegram Bot ──
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=@your_bot_username

# Webhook URL (leave blank for polling mode)
WEBHOOK_URL=

# Port for Flask health server
PORT=8080

# ── Admin ──
# Primary admin user ID
ADMIN_USER_ID=123456789

# Comma-separated extra admin IDs (optional)
ADMIN_IDS=123456789,987654321

# ── Channel Membership Gate ──
# Leave blank to disable membership requirement
REQUIRED_CHANNEL_USERNAME=@YourChannel
REQUIRED_CHANNEL_URL=https://t.me/YourChannel
CHANNEL_LINK=YourChannel
SUPPORT_USERNAME=YourSupportHandle

# ── DiskWala API ──
DISKWALA_API_KEY=your_diskwala_api_key
DISKWALA_BASE_URL=https://ddudapidd.diskwala.com/api/v1

# ── MongoDB (for DB_CHANNEL cache + premium system) ──
MONGO_DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
DB_CHANNEL=-100xxxxxxxxxx

# ── Pyrogram (for multi-bot uploads & DB_CHANNEL) ──
# Get from https://my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here

# Comma-separated tokens of support bots (optional, for parallel uploads)
# Example: token1,token2,token3
SUPPORT_BOT_TOKENS=

# ── Premium / UPI Payment ──
UPI_ID=yourname@upi
UPI_NAME=Your Name

# ── Free user download limit ──
FREE_DOWNLOAD_LIMIT=10

# ── Media URLs ──
# Welcome photo (shown on /start)
PHOTO_URL=https://i.imgur.com/yourwelcome.jpg

# Dummy image shown after 1-hour video deletion
DUMMY_URL=https://i.imgur.com/yourdummy.jpg
